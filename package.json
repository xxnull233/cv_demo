{
  "name": "cv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "node scripts/start-web.js",
    "web:direct": "expo start --web",
    "build:android": "eas build -p android --profile preview --clear-cache",
    "check": "node scripts/check.js && node scripts/parser-check.js",
    "cg:status": "npx -p @colbymchenry/codegraph codegraph status",
    "cg:sync": "npx -p @colbymchenry/codegraph codegraph sync",
    "cg:search": "npx -p @colbymchenry/codegraph codegraph search",
    "cg:explore": "npx -p @colbymchenry/codegraph codegraph explore",
    "cg:context": "npx -p @colbymchenry/codegraph codegraph context"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "^53.0.0",
    "expo-build-properties": "~0.14.8",
    "expo-clipboard": "^55.0.13",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-video": "~2.2.2",
    "expo-video-cache": "^2.1.0",
    "hls.js": "^1.6.16",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-toast-message": "^2.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@colbymchenry/codegraph": "^0.9.4",
    "@expo/metro-runtime": "~5.0.5",
    "react-dom": "19.0.0",
    "react-native-web": "^0.20.0"
  }
}
